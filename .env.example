# =============================================================================
# Environment variables template for Vercel deployment
# =============================================================================
# DO NOT put real secrets in this file.
# This is just a list of variables you need to add in Vercel's dashboard:
# Vercel Project > Settings > Environment Variables
#
# For each variable below, add it in Vercel for: Production, Preview, Development
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=

# --- Session / cookies ---
SESSION_SECRET=

# --- Clerk authentication ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# --- OxaPay (crypto payments) ---
OXAPAY_MERCHANT_API_KEY=

# --- Hero SMS provider ---
HERO_SMS_API_KEY=

# --- Google OAuth (if used) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin account ---
ADMIN_EMAIL=

# --- Optional: log level ---
# LOG_LEVEL=info
