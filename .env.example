# =============================================================================
# Environment variables template for Vercel deployment
# =============================================================================
# DO NOT put real secrets in this file.
# Add these in Vercel: Project > Settings > Environment Variables
# For each variable, enable: Production, Preview, Development
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=

# --- Session / cookies (any long random string) ---
SESSION_SECRET=

# --- Google OAuth (for "Sign in with Google") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OxaPay (crypto payments) ---
OXAPAY_MERCHANT_API_KEY=

# --- Hero SMS provider ---
HERO_SMS_API_KEY=

# --- Admin account ---
ADMIN_EMAIL=

# --- Optional: log level ---
# LOG_LEVEL=info
