{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile --config.minimum-release-age=0 --config.minimum-release-age-exclude=''",
  "buildCommand": "pnpm --filter @workspace/api-server run build:vercel && pnpm --filter @workspace/sim-rentals run build:cloudflare",
  "outputDirectory": "artifacts/sim-rentals/dist/cloudflare",
  "functions": {
    "api/[...all].mjs": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/((?!api/|assets/|favicon\\.svg|opengraph\\.jpg|_redirects).*)", "destination": "/index.html" }
  ]
}
